# NetivLang Machine-Lowered Reserved Words List

# 1. 64-Bit General Purpose CPU Registers
rax
rcx
rdx
rbx
rsp
rbp
rsi
rdi
r8
r9
r10
r11
r12
r13
r14
r15

# 2. 8-Bit, 16-Bit, and 32-Bit Register Sub-Bytes
rax_u8
rax_u16
rax_u32

# 3. SSE Floating Point Registers
xmm0
xmm1
xmm2
xmm3
xmm4
xmm5
xmm6
xmm7

# 4. Low-Level Memory Dereferencing Operators
*(u8*)
*(u16*)
*(u32*)
*(u64*)
*(f32*)
*(f64*)

# 5. Core Assembler Emitter Keywords
cmp_rax
if_z_goto
if_ne_goto
if_z_return
rax_is_null
syscall
call
goto
label
return
EMIT_PE

# 6. Binary x64 Mathematical & Logic Operators
+
-
*
/
&
|
^
<<
>>
==
!=
<
>
