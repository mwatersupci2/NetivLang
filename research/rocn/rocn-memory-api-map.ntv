    <meta>{
      name: "rocn.memory_api_map",
      kind: "research-flatfile",
      namespace: "research.rocn",
      version: "0.1.0",
      status: "research-draft",
      source_model: "conceptual API map",
      upstream_project: "ROCm/HIP",
      upstream_repo: "ROCm/hip",
      upstream_files: "docs/reference/hip_runtime_api/modules/memory_management.rst; docs/reference/hip_runtime_api/modules/memory_management/stream_ordered_memory_allocator.rst; docs/reference/hip_runtime_api/modules/memory_management/unified_memory_reference.rst; docs/reference/hip_runtime_api/modules/memory_management/virtual_memory_reference.rst; docs/reference/hip_runtime_api/modules/memory_management/texture_management.rst; docs/reference/hip_runtime_api/modules/memory_management/surface_object.rst",
      upstream_ref: "develop",
      upstream_license: "MIT License observed in ROCm/HIP LICENSE.md",
