      %%   ProgramHandle --> DestroyProgram
      %%   CompileOptions --> TargetArchitecture
      %%   CompileOptions --> ClangOptions
      %%   CompilationLog --> Warnings
      %%   CompilationLog --> Errors
      %%   CodeObject --> GetCodeSize
      %%   CodeObject --> GetCode
      %%   ModuleLoad --> LoadCompiledBinary
      %%   FunctionLookup --> ResolveKernelSymbol
      %%   ModuleLaunch --> LaunchCompiledKernel
