<Netiv="research/rocn/rocn-runtime-compilation-map.ntv">
○|
  □|
    <meta>{
      name: "rocn.runtime_compilation_map",
      kind: "research-flatfile",
      namespace: "research.rocn",
      version: "0.1.0",
      status: "research-draft",
      source_model: "conceptual API map",
      upstream_project: "ROCm/HIP",
      upstream_repo: "ROCm/hip",
      upstream_files: "docs/reference/hip_runtime_api/modules/runtime_compilation.rst; docs/how-to/hip_rtc.rst; include/hip/hiprtc.h",
      upstream_ref: "develop",
      upstream_license: "MIT License observed in ROCm/HIP LICENSE.md",
      upstream_owner: "Advanced Micro Devices, Inc.",
      attribution: "ROCm, HIP, AMD, and related project names, marks, code, documentation, and intellectual property belong to their respective owners. ROCN is independent Netiv research and is not an official AMD project.",
      copied_source: false,
      notes: "This flatfile maps HIP runtime-compilation concepts into ROCN research terms. It does not copy declarations or implement runtime compilation."
    };</meta>

    <edges>{
      %% graph TD
      %%   ROCNRuntimeCompilationMap --> SourceText
      %%   ROCNRuntimeCompilationMap --> ProgramHandle
      %%   ROCNRuntimeCompilationMap --> Headers
      %%   ROCNRuntimeCompilationMap --> CompileOptions
