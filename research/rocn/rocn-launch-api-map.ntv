<Netiv="research/rocn/rocn-launch-api-map.ntv">
○|
  □|
    <meta>{
      name: "rocn.launch_api_map",
      kind: "research-flatfile",
      namespace: "research.rocn",
      version: "0.1.0",
      status: "research-draft",
      source_model: "conceptual API map",
      upstream_project: "ROCm/HIP",
      upstream_repo: "ROCm/hip",
      upstream_files: "docs/reference/hip_runtime_api/modules/launch_api.rst; docs/reference/hip_runtime_api/modules/execution_control.rst; docs/how-to/hip_cpp_language_extensions.rst",
      upstream_ref: "develop",
      upstream_license: "MIT License observed in ROCm/HIP LICENSE.md",
      upstream_owner: "Advanced Micro Devices, Inc.",
      attribution: "ROCm, HIP, AMD, and related project names, marks, code, documentation, and intellectual property belong to their respective owners. ROCN is independent Netiv research and is not an official AMD project.",
      copied_source: false,
      notes: "This flatfile maps HIP launch and execution-control concepts into ROCN research terms. It does not copy function declarations, implement triple-chevron syntax, or define an ABI wrapper yet."
    };</meta>

    <edges>{
      %% graph TD
      %%   ROCNLaunchAPIMap --> KernelSymbol
      %%   ROCNLaunchAPIMap --> LaunchGeometry
      %%   ROCNLaunchAPIMap --> SharedMemoryRequest
      %%   ROCNLaunchAPIMap --> StreamTarget
      %%   ROCNLaunchAPIMap --> KernelArguments
