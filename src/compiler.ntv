fn ntv_main() -> void {
    EMIT_PE
    
    // Resolve compiler
    rax = syscall 9
    rbx = rax
    
    // Resolve self statements
    rcx = "ntv_compiler"
    rax = syscall 3
    rcx = rax
    
    // Setup arguments
    rdx = ptr
    rax = ptr
    rax = rax + 0x10000
    r8 = rax
    r9 = r13
    
    // Call compiler
    rax = rbx
    call rax
    
    // Size is in rax, but ptr is already advanced
    rax = 0
    return
}
