<Netiv="adj_mermaid.ntv">
○|
  □|
    <meta>{
      "type": "module",
      "name": "adj",
      "id": "adj.mermaid",
      "version": "1.0.0",
      "error": "terminal",
      "notes": "Unified Mermaid graph relationship exporter. Section 1 defines MermaidExporter state block, Section 2 handles buffer writes with capacity boundary checks, and Section 3 exposes node/edge serialization and direct file saving."
    };

    <edges>{};

    <book>{
      °struct •MermaidExporter {
        •buffer: °pointer<°u8>,
        •cursor: °pointer<°u8>,
        •capacity: °usize,
        •length: °usize
      }

      °function •mermaid_init(•exporter: °pointer<°struct •MermaidExporter>, •buffer: °pointer<°void>, •capacity: °usize) -> °void {
        °unsafe {
            *(°pointer<°void>*)(•exporter) = •buffer
            *(°pointer<°void>*)(•exporter + 8) = •buffer
            *(°usize*)(•exporter + 16) = •capacity
            *(°usize*)(•exporter + 24) = 0

            °call •mermaid_write_str(•exporter, "graph TD\r\n")
            return
        }
      }

      °function •mermaid_write_str(•exporter: °pointer<°struct •MermaidExporter>, •str: °pointer<°const °u8>) -> °void {
        °unsafe {
            °pointer<°u8> •cursor
            •cursor = *(°pointer<°u8>*)(•exporter + 8)
            °usize •capacity
            •capacity = *(°usize*)(•exporter + 16)
            °usize •len
            •len = *(°usize*)(•exporter + 24)

            °usize •i
            •i = 0
            °label str_loop
            °u8 •char
            •char = *(°u8*)(•str + •i)
            °if (•char == 0) {
                °goto str_done
            }
            
            °if (•len >= •capacity) {
                °goto str_done
            }

            *•cursor = •char
            •cursor = •cursor + 1
            •len = •len + 1
            •i = •i + 1
            °goto str_loop

            °label str_done
            *(°pointer<°u8>*)(•exporter + 8) = •cursor
            *(°usize*)(•exporter + 24) = •len
            return
        }
      }

      °function •mermaid_add_node(•exporter: °pointer<°struct •MermaidExporter>, •node_id: °pointer<°const °u8>, •label: °pointer<°const °u8>) -> °void {
        °unsafe {
            °call •mermaid_write_str(•exporter, "    ")
            °call •mermaid_write_str(•exporter, •node_id)
            °call •mermaid_write_str(•exporter, "[\"")
            °call •mermaid_write_str(•exporter, •label)
            °call •mermaid_write_str(•exporter, "\"]\r\n")
            return
        }
      }

      °function •mermaid_add_edge(•exporter: °pointer<°struct •MermaidExporter>, •from_id: °pointer<°const °u8>, •to_id: °pointer<°const °u8>) -> °void {
        °unsafe {
            °call •mermaid_write_str(•exporter, "    ")
            °call •mermaid_write_str(•exporter, •from_id)
            °call •mermaid_write_str(•exporter, " --> ")
            °call •mermaid_write_str(•exporter, •to_id)
            °call •mermaid_write_str(•exporter, "\r\n")
            return
        }
      }

      °function •mermaid_save(•exporter: °pointer<°struct •MermaidExporter>, •path: °pointer<°const °u8>) -> °usize {
        °unsafe {
            °pointer<°void> •buffer
            •buffer = *(°pointer<°void>*)(•exporter)
            °usize •len
            •len = *(°usize*)(•exporter + 24)

            °call •save_binary(•path, •buffer, •len)
            return rax
        }
      }
    };
  |■
|●
</Netiv>
