    <book>{
      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3Transform(
          •v: •Vector3,
          •mat: •Matrix
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °define •x: °f32;
        °set •x = •v.x;
        °define •y: °f32;
        °set •y = •v.y;
        °define •z: °f32;
        °set •z = •v.z;
        °set •result.x = •mat.m0 * •x + •mat.m4 * •y + •mat.m8 * •z + •mat.m12;
        °set •result.y = •mat.m1 * •x + •mat.m5 * •y + •mat.m9 * •z + •mat.m13;
        °set •result.z = •mat.m2 * •x + •mat.m6 * •y + •mat.m10 * •z + •mat.m14;
        °return •result;
      };
    };
