    <book>{
      °struct •Vector4 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
        •w: °f32;
      };

      °function •Vector4Lerp(
          •v1: •Vector4,
          •v2: •Vector4,
          •amount: °f32
      ) -> •Vector4 {
        °define •result: •Vector4;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °set •result.w = 0.0;
        °set •result.x = •v1.x + •amount * •v2.x - •v1.x;
        °set •result.y = •v1.y + •amount * •v2.y - •v1.y;
        °set •result.z = •v1.z + •amount * •v2.z - •v1.z;
        °set •result.w = •v1.w + •amount * •v2.w - •v1.w;
        °return •result;
      };
    };
