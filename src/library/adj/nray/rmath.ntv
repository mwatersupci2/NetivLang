    };

    <book>{
      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3ClampValue(
          •v: •Vector3,
          •source_min: °f32,
          •source_max: °f32
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result = •v;
        °define •length: °f32;
        °set •length = •v.x * •v.x + •v.y * •v.y + •v.z * •v.z;
        °if (•length > 0.0) {
          °set •length = •sqrtf(•length);
          °define •scale: °f32;
          °set •scale = 1;
          °if (•length < •source_min) {
            °set •scale = •source_min / •length;
          };
          °otherwise {
            °if (•length > •source_max) {
              °set •scale = •source_max / •length;
            };
          };
          °set •result.x = •v.x * •scale;
          °set •result.y = •v.y * •scale;
          °set •result.z = •v.z * •scale;
        };
        °return •result;
      };
    };
