          °set •angle = •angle * 0.5;
          °define •ilength: °f32;
          °set •ilength = 1.0 / •length;
          °set •axis.x = •axis.x * •ilength;
          °set •axis.y = •axis.y * •ilength;
          °set •axis.z = •axis.z * •ilength;
          °define •sinres: °f32;
          °set •sinres = •sinf(•angle);
          °define •cosres: °f32;
          °set •cosres = •cosf(•angle);
          °set •result.x = •axis.x * •sinres;
          °set •result.y = •axis.y * •sinres;
          °set •result.z = •axis.z * •sinres;
          °set •result.w = •cosres;
          °define •q: •Quaternion;
          °set •q = •result;
          °set •length = •sqrtf(•q.x * •q.x + •q.y * •q.y + •q.z * •q.z + •q.w * •q.w);
