      °function •Vector3OrthoNormalize(
          •v1: °pointer<•Vector3>,
          •v2: °pointer<•Vector3>
      ) -> °void {
        °define •length: °f32;
        °set •length = 0.0;
        °define •ilength: °f32;
        °set •ilength = 0.0;
        °define •v: •Vector3;
        °set •v = °deref(•v1);
        °set •length = •sqrtf(•v.x * •v.x + •v.y * •v.y + •v.z * •v.z);
        °if (•length == 0.0) {
          °set •length = 1.0;
        };
        °set •ilength = 1.0 / •length;
        °set °deref(•v1).x = °deref(•v1).x * •ilength;
        °set °deref(•v1).y = °deref(•v1).y * •ilength;
        °set °deref(•v1).z = °deref(•v1).z * •ilength;
        °define •vn1: •Vector3;
        °set •vn1.x = °deref(•v1).y * °deref(•v2).z - °deref(•v1).z * °deref(•v2).y;
        °set •vn1.y = °deref(•v1).z * °deref(•v2).x - °deref(•v1).x * °deref(•v2).z;
        °set •vn1.z = °deref(•v1).x * °deref(•v2).y - °deref(•v1).y * °deref(•v2).x;
        °set •v = •vn1;
        °set •length = •sqrtf(•v.x * •v.x + •v.y * •v.y + •v.z * •v.z);
        °if (•length == 0.0) {
          °set •length = 1.0;
        };
        °set •ilength = 1.0 / •length;
        °set •vn1.x = •vn1.x * •ilength;
        °set •vn1.y = •vn1.y * •ilength;
        °set •vn1.z = •vn1.z * •ilength;
        °define •vn2: •Vector3;
        °set •vn2.x = •vn1.y * °deref(•v1).z - •vn1.z * °deref(•v1).y;
        °set •vn2.y = •vn1.z * °deref(•v1).x - •vn1.x * °deref(•v1).z;
        °set •vn2.z = •vn1.x * °deref(•v1).y - •vn1.y * °deref(•v1).x;
        °set °deref(•v2) = •vn2;
      };
