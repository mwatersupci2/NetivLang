      °function •QuaternionFromEuler(
          •pitch: °f32,
          •yaw: °f32,
          •roll: °f32
      ) -> •Quaternion {
        °define •result: •Quaternion;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °set •result.w = 0.0;
        °define •x0: °f32;
        °set •x0 = •cosf(•pitch * 0.5);
        °define •x1: °f32;
        °set •x1 = •sinf(•pitch * 0.5);
        °define •y0: °f32;
        °set •y0 = •cosf(•yaw * 0.5);
        °define •y1: °f32;
        °set •y1 = •sinf(•yaw * 0.5);
        °define •z0: °f32;
        °set •z0 = •cosf(•roll * 0.5);
        °define •z1: °f32;
        °set •z1 = •sinf(•roll * 0.5);
        °set •result.x = •x1 * •y0 * •z0 - •x0 * •y1 * •z1;
        °set •result.y = •x0 * •y1 * •z0 + •x1 * •y0 * •z1;
        °set •result.z = •x0 * •y0 * •z1 - •x1 * •y1 * •z0;
        °set •result.w = •x0 * •y0 * •z0 + •x1 * •y1 * •z1;
        °return •result;
      };
    };
