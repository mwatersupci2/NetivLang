    <book>{
      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3Clamp(
          •v: •Vector3,
          •source_min: •Vector3,
          •source_max: •Vector3
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °set •result.x = •fminf(•source_max.x, •fmaxf(•source_min.x, •v.x));
        °set •result.y = •fminf(•source_max.y, •fmaxf(•source_min.y, •v.y));
        °set •result.z = •fminf(•source_max.z, •fmaxf(•source_min.z, •v.z));
        °return •result;
      };
    };
