    };

    <book>{
      °struct •Matrix {
        •m0: °f32;
        •m4: °f32;
        •m8: °f32;
        •m12: °f32;
        •m1: °f32;
        •m5: °f32;
        •m9: °f32;
        •m13: °f32;
        •m2: °f32;
        •m6: °f32;
        •m10: °f32;
        •m14: °f32;
        •m3: °f32;
        •m7: °f32;
        •m11: °f32;
        •m15: °f32;
      };

      °function •MatrixRotate(
          •axis: •Vector3,
          •angle: °f32
      ) -> •Matrix {
        °define •result: •Matrix;
        °set •result.m0 = 0.0;
        °set •result.m4 = 0.0;
        °set •result.m8 = 0.0;
        °set •result.m12 = 0.0;
        °set •result.m1 = 0.0;
        °set •result.m5 = 0.0;
        °set •result.m9 = 0.0;
        °set •result.m13 = 0.0;
        °set •result.m2 = 0.0;
        °set •result.m6 = 0.0;
        °set •result.m10 = 0.0;
        °set •result.m14 = 0.0;
        °set •result.m3 = 0.0;
        °set •result.m7 = 0.0;
        °set •result.m11 = 0.0;
        °set •result.m15 = 0.0;
        °define •x: °f32;
        °set •x = •axis.x;
        °define •y: °f32;
        °set •y = •axis.y;
        °define •z: °f32;
        °set •z = •axis.z;
        °define •lengthSquared: °f32;
        °set •lengthSquared = •x * •x + •y * •y + •z * •z;
        °if (•lengthSquared != 1.0 && •lengthSquared != 0.0) {
          °define •ilength: °f32;
          °set •ilength = 1.0 / •sqrtf(•lengthSquared);
          °set •x = •x * •ilength;
          °set •y = •y * •ilength;
          °set •z = •z * •ilength;
        };
        °define •sinres: °f32;
        °set •sinres = •sinf(•angle);
        °define •cosres: °f32;
        °set •cosres = •cosf(•angle);
        °define •t: °f32;
        °set •t = 1.0 - •cosres;
        °set •result.m0 = •x * •x * •t + •cosres;
        °set •result.m1 = •y * •x * •t + •z * •sinres;
        °set •result.m2 = •z * •x * •t - •y * •sinres;
        °set •result.m3 = 0.0;
        °set •result.m4 = •x * •y * •t - •z * •sinres;
        °set •result.m5 = •y * •y * •t + •cosres;
        °set •result.m6 = •z * •y * •t + •x * •sinres;
        °set •result.m7 = 0.0;
        °set •result.m8 = •x * •z * •t + •y * •sinres;
        °set •result.m9 = •y * •z * •t - •x * •sinres;
        °set •result.m10 = •z * •z * •t + •cosres;
        °set •result.m11 = 0.0;
        °set •result.m12 = 0.0;
        °set •result.m13 = 0.0;
        °set •result.m14 = 0.0;
        °set •result.m15 = 1.0;
        °return •result;
      };
    };
