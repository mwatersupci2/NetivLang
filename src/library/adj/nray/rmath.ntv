    <book>{
      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3Refract(
          •v: •Vector3,
          •n: •Vector3,
          •r: °f32
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °define •dot: °f32;
        °set •dot = •v.x * •n.x + •v.y * •n.y + •v.z * •n.z;
        °define •d: °f32;
        °set •d = 1.0 - •r * •r * 1.0 - •dot * •dot;
        °if (•d >= 0.0) {
          °set •d = •sqrtf(•d);
          °set •v.x = •r * •v.x - •r * •dot + •d * •n.x;
          °set •v.y = •r * •v.y - •r * •dot + •d * •n.y;
          °set •v.z = •r * •v.z - •r * •dot + •d * •n.z;
          °set •result = •v;
        };
        °return •result;
      };
    };
