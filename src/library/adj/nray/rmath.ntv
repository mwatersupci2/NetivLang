      page: 5,
      source: "RMath Library.pdf"
    };

    <edges>{
      %% RMath Library.pdf -> Wrap
      %% Wrap -> DivideScalar
      %% Wrap -> f32
      %% Wrap -> floorf
      %% Wrap -> MultiplyScalar
      %% Wrap -> SubtractScalar
    };

    <book>{
      °function •Wrap(
          •value: °f32,
          •source_min: °f32,
          •source_max: °f32
      ) -> °f32 {
        °define •result: °f32;
        °set •result = •value - •source_max - •source_min * •floorf(•value - •source_min / •source_max - •source_min);
        °return •result;
      };
    };
