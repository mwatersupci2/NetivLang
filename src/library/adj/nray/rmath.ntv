    <book>{
      °function •Vector4Equals(
          •p: •Vector4,
          •q: •Vector4
      ) -> °i64 {
        °define •result: °i64;
        °set •result = •fabsf(•p.x - •q.x) <= •EPSILON * •fmaxf(1.0, •fmaxf(•fabsf(•p.x), •fabsf(•q.x))) && •fabsf(•p.y - •q.y) <= •EPSILON * •fmaxf(1.0, •fmaxf(•fabsf(•p.y), •fabsf(•q.y))) && •fabsf(•p.z - •q.z) <= •EPSILON * •fmaxf(1.0, •fmaxf(•fabsf(•p.z), •fabsf(•q.z))) && •fabsf(•p.w - •q.w) <= •EPSILON * •fmaxf(1.0, •fmaxf(•fabsf(•p.w), •fabsf(•q.w)));
        °return •result;
      };
    };
