        °set •qaz = •q1.z;
        °define •qaw: °f32;
        °set •qaw = •q1.w;
        °define •qbx: °f32;
        °set •qbx = •q2.x;
        °define •qby: °f32;
        °set •qby = •q2.y;
        °define •qbz: °f32;
        °set •qbz = •q2.z;
        °define •qbw: °f32;
        °set •qbw = •q2.w;
        °set •result.x = •qax * •qbw + •qaw * •qbx + •qay * •qbz - •qaz * •qby;
        °set •result.y = •qay * •qbw + •qaw * •qby + •qaz * •qbx - •qax * •qbz;
        °set •result.z = •qaz * •qbw + •qaw * •qbz + •qax * •qby - •qay * •qbx;
        °set •result.w = •qaw * •qbw - •qax * •qbx - •qay * •qby - •qaz * •qbz;
        °return •result;
