    <book>{
      °struct •Quaternion {
        •x: °f32;
        •y: °f32;
        •z: °f32;
        •w: °f32;
      };

      °function •QuaternionInvert(
          •q: •Quaternion
      ) -> •Quaternion {
        °define •result: •Quaternion;
        °set •result = •q;
        °define •lengthSq: °f32;
        °set •lengthSq = •q.x * •q.x + •q.y * •q.y + •q.z * •q.z + •q.w * •q.w;
        °if (•lengthSq != 0.0) {
          °define •invLength: °f32;
          °set •invLength = 1.0 / •lengthSq;
          °set •result.x = •result.x * -•invLength;
          °set •result.y = •result.y * -•invLength;
          °set •result.z = •result.z * -•invLength;
          °set •result.w = •result.w * •invLength;
        };
        °return •result;
      };
    };
