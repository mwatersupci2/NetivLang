      %% RMath Library.pdf -> Normalize
    };

    <book>{
      °function •Normalize(
          •value: °f32,
          •start: °f32,
          •end: °f32
      ) -> °f32 {
        °define •result: °f32;
        °set •result = •value - •start / •end - •start;
        °return •result;
      };
    };
