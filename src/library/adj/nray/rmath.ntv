        °set •fourWSquaredMinus1 = •mat.m0 + •mat.m5 + •mat.m10;
        °define •fourXSquaredMinus1: °f32;
        °set •fourXSquaredMinus1 = •mat.m0 - •mat.m5 - •mat.m10;
        °define •fourYSquaredMinus1: °f32;
        °set •fourYSquaredMinus1 = •mat.m5 - •mat.m0 - •mat.m10;
        °define •fourZSquaredMinus1: °f32;
        °set •fourZSquaredMinus1 = •mat.m10 - •mat.m0 - •mat.m5;
        °define •biggestIndex: °i64;
        °set •biggestIndex = 0;
        °define •fourBiggestSquaredMinus1: °f32;
        °set •fourBiggestSquaredMinus1 = •fourWSquaredMinus1;
        °if (•fourXSquaredMinus1 > •fourBiggestSquaredMinus1) {
