        °set •result.x = •v.y * •cardinalAxis.z - •v.z * •cardinalAxis.y;
        °set •result.y = •v.z * •cardinalAxis.x - •v.x * •cardinalAxis.z;
        °set •result.z = •v.x * •cardinalAxis.y - •v.y * •cardinalAxis.x;
        °return •result;
