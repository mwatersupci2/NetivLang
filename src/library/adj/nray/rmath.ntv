        °if (•fabsf(•v.y) < •source_min) {
          °set •source_min = •fabsf(•v.y);
          °define •tmp: •Vector3;
          °set •tmp.x = 0.0;
          °set •tmp.y = 1.0;
          °set •tmp.z = 0.0;
          °set •cardinalAxis = •tmp;
