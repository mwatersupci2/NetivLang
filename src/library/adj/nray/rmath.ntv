        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3Normalize(
          •v: •Vector3
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result = •v;
        °define •length: °f32;
        °set •length = •sqrtf(•v.x * •v.x + •v.y * •v.y + •v.z * •v.z);
