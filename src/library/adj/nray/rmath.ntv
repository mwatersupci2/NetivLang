    };

    <edges>{
      %% RMath Library.pdf -> Vector3ClampValue
      %% Vector3ClampValue -> AddScalar
      %% Vector3ClampValue -> CompareScalar
      %% Vector3ClampValue -> ConditionalFlow
      %% Vector3ClampValue -> DivideScalar
