            °set •result.x = •biggestVal;
            °set •result.w = •mat.m6 - •mat.m9 * •mult;
            °set •result.y = •mat.m1 + •mat.m4 * •mult;
            °set •result.z = •mat.m8 + •mat.m2 * •mult;
            °break;
