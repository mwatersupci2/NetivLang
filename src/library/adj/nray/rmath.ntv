        °define •ilength: °f32;
        °set •ilength = 1.0 / •length;
        °set •axis.x = •axis.x * •ilength;
        °set •axis.y = •axis.y * •ilength;
        °set •axis.z = •axis.z * •ilength;
        °set •angle = •angle / 2.0;
        °define •a: °f32;
        °set •a = •sinf(•angle);
        °define •b: °f32;
        °set •b = •axis.x * •a;
        °define •c: °f32;
        °set •c = •axis.y * •a;
        °define •d: °f32;
        °set •d = •axis.z * •a;
        °set •a = •cosf(•angle);
        °define •w: •Vector3;
        °set •w.x = •b;
