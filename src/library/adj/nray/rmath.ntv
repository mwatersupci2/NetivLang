    <edges>{
      %% FloatEquals -> CompareScalar
      %% FloatEquals -> ConditionalFlow
      %% FloatEquals -> EPSILON
      %% FloatEquals -> f32
      %% FloatEquals -> fabsf
      %% FloatEquals -> fmaxf
      %% FloatEquals -> i64
      %% FloatEquals -> MultiplyScalar
      %% FloatEquals -> SubtractScalar
      %% RMath Library.pdf -> FloatEquals
    };

    <book>{
      °function •FloatEquals(
          •x: °f32,
          •y: °f32
      ) -> °i64 {
        °define •result: °i64;
        °set •result = •fabsf(•x - •y) <= •EPSILON * •fmaxf(1.0, •fmaxf(•fabsf(•x), •fabsf(•y)));
        °return •result;
      };
    };
