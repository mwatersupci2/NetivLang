    <book>{
      °struct •Vector4 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
        •w: °f32;
      };

      °function •Vector4Invert(
          •v: •Vector4
      ) -> •Vector4 {
        °define •result: •Vector4;
        °set •result.x = 1.0 / •v.x;
        °set •result.y = 1.0 / •v.y;
        °set •result.z = 1.0 / •v.z;
        °set •result.w = 1.0 / •v.w;
        °return •result;
      };
    };
