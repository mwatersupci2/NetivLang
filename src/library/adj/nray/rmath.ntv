        •z: °f32;
      };

      °function •Vector3Barycenter(
          •p: •Vector3,
          •a: •Vector3,
          •b: •Vector3,
          •c: •Vector3
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °define •v0: •Vector3;
        °set •v0.x = •b.x - •a.x;
        °set •v0.y = •b.y - •a.y;
        °set •v0.z = •b.z - •a.z;
        °define •v1: •Vector3;
        °set •v1.x = •c.x - •a.x;
        °set •v1.y = •c.y - •a.y;
        °set •v1.z = •c.z - •a.z;
        °define •v2: •Vector3;
        °set •v2.x = •p.x - •a.x;
        °set •v2.y = •p.y - •a.y;
        °set •v2.z = •p.z - •a.z;
        °define •d00: °f32;
        °set •d00 = •v0.x * •v0.x + •v0.y * •v0.y + •v0.z * •v0.z;
        °define •d01: °f32;
        °set •d01 = •v0.x * •v1.x + •v0.y * •v1.y + •v0.z * •v1.z;
        °define •d11: °f32;
        °set •d11 = •v1.x * •v1.x + •v1.y * •v1.y + •v1.z * •v1.z;
        °define •d20: °f32;
        °set •d20 = •v2.x * •v0.x + •v2.y * •v0.y + •v2.z * •v0.z;
        °define •d21: °f32;
        °set •d21 = •v2.x * •v1.x + •v2.y * •v1.y + •v2.z * •v1.z;
        °define •denom: °f32;
        °set •denom = •d00 * •d11 - •d01 * •d01;
        °set •result.y = •d11 * •d20 - •d01 * •d21 / •denom;
        °set •result.z = •d00 * •d21 - •d01 * •d20 / •denom;
        °set •result.x = 1.0 - •result.z + •result.y;
        °return •result;
      };
    };
