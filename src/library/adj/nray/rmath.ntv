    <book>{
      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3Invert(
          •v: •Vector3
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 1.0 / •v.x;
        °set •result.y = 1.0 / •v.y;
        °set •result.z = 1.0 / •v.z;
        °return •result;
      };
    };
