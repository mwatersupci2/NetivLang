        °define •biggestVal: °f32;
        °set •biggestVal = •sqrtf(•fourBiggestSquaredMinus1 + 1.0) * 0.5;
        °define •mult: °f32;
        °set •mult = 0.25 / •biggestVal;
        °switch (•biggestIndex) {
          °case 0 {
            °set •result.w = •biggestVal;
            °set •result.x = •mat.m6 - •mat.m9 * •mult;
            °set •result.y = •mat.m8 - •mat.m2 * •mult;
            °set •result.z = •mat.m1 - •mat.m4 * •mult;
