    <book>{
      °struct •Quaternion {
        •x: °f32;
        •y: °f32;
        •z: °f32;
        •w: °f32;
      };

      °function •QuaternionSlerp(
          •q1: •Quaternion,
          •q2: •Quaternion,
          •amount: °f32
      ) -> •Quaternion {
        °define •result: •Quaternion;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °set •result.w = 0.0;
        °define •cosHalfTheta: °f32;
        °set •cosHalfTheta = •q1.x * •q2.x + •q1.y * •q2.y + •q1.z * •q2.z + •q1.w * •q2.w;
        °if (•cosHalfTheta < 0) {
          °set •q2.x = -•q2.x;
          °set •q2.y = -•q2.y;
          °set •q2.z = -•q2.z;
          °set •q2.w = -•q2.w;
          °set •cosHalfTheta = -•cosHalfTheta;
        };
        °if (•fabsf(•cosHalfTheta) >= 1.0) {
          °set •result = •q1;
        };
        °otherwise {
          °if (•cosHalfTheta > 0.95) {
            °set •result = •QuaternionNlerp(•q1, •q2, •amount);
          };
          °otherwise {
            °define •halfTheta: °f32;
            °set •halfTheta = •acosf(•cosHalfTheta);
            °define •sinHalfTheta: °f32;
            °set •sinHalfTheta = •sqrtf(1.0 - •cosHalfTheta * •cosHalfTheta);
            °if (•fabsf(•sinHalfTheta) < •EPSILON) {
              °set •result.x = •q1.x * 0.5 + •q2.x * 0.5;
              °set •result.y = •q1.y * 0.5 + •q2.y * 0.5;
              °set •result.z = •q1.z * 0.5 + •q2.z * 0.5;
              °set •result.w = •q1.w * 0.5 + •q2.w * 0.5;
            };
            °otherwise {
              °define •ratioA: °f32;
              °set •ratioA = •sinf(1 - •amount * •halfTheta) / •sinHalfTheta;
              °define •ratioB: °f32;
              °set •ratioB = •sinf(•amount * •halfTheta) / •sinHalfTheta;
              °set •result.x = •q1.x * •ratioA + •q2.x * •ratioB;
              °set •result.y = •q1.y * •ratioA + •q2.y * •ratioB;
              °set •result.z = •q1.z * •ratioA + •q2.z * •ratioB;
              °set •result.w = •q1.w * •ratioA + •q2.w * •ratioB;
            };
          };
        };
        °return •result;
      };
    };
