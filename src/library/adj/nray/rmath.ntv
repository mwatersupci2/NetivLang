      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3Perpendicular(
          •v: •Vector3
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
