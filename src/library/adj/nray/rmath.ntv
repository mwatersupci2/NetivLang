    <edges>{
      %% RMath Library.pdf -> Vector4MoveTowards
      %% Vector4MoveTowards -> AddScalar
      %% Vector4MoveTowards -> CompareScalar
      %% Vector4MoveTowards -> ConditionalFlow
      %% Vector4MoveTowards -> DivideScalar
      %% Vector4MoveTowards -> f32
      %% Vector4MoveTowards -> MultiplyScalar
      %% Vector4MoveTowards -> sqrtf
      %% Vector4MoveTowards -> SubtractScalar
      %% Vector4MoveTowards -> Vector4
    };

    <book>{
      °struct •Vector4 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
        •w: °f32;
      };

      °function •Vector4MoveTowards(
          •v: •Vector4,
          •target: •Vector4,
          •maxDistance: °f32
      ) -> •Vector4 {
        °define •result: •Vector4;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °set •result.w = 0.0;
        °define •dx: °f32;
        °set •dx = •target.x - •v.x;
        °define •dy: °f32;
        °set •dy = •target.y - •v.y;
        °define •dz: °f32;
        °set •dz = •target.z - •v.z;
        °define •dw: °f32;
        °set •dw = •target.w - •v.w;
        °define •value: °f32;
        °set •value = •dx * •dx + •dy * •dy + •dz * •dz + •dw * •dw;
        °if (•value == 0 || •maxDistance >= 0 && •value <= •maxDistance * •maxDistance) {
          °return •target;
        };
        °define •dist: °f32;
        °set •dist = •sqrtf(•value);
        °set •result.x = •v.x + •dx / •dist * •maxDistance;
        °set •result.y = •v.y + •dy / •dist * •maxDistance;
        °set •result.z = •v.z + •dz / •dist * •maxDistance;
        °set •result.w = •v.w + •dw / •dist * •maxDistance;
        °return •result;
      };
    };
