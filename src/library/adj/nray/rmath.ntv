      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •QuaternionToEuler(
          •q: •Quaternion
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °define •x0: °f32;
        °set •x0 = 2.0 * •q.w * •q.x + •q.y * •q.z;
        °define •x1: °f32;
        °set •x1 = 1.0 - 2.0 * •q.x * •q.x + •q.y * •q.y;
        °set •result.x = •atan2f(•x0, •x1);
        °define •y0: °f32;
        °set •y0 = 2.0 * •q.w * •q.y - •q.z * •q.x;
        °if (•y0 > 1.0) {
          °set •y0 = 1.0;
        };
        °otherwise {
          °set •y0 = •y0;
        };
        °if (•y0 < -1.0) {
          °set •y0 = -1.0;
        };
        °otherwise {
          °set •y0 = •y0;
        };
        °set •result.y = •asinf(•y0);
        °define •z0: °f32;
        °set •z0 = 2.0 * •q.w * •q.z + •q.x * •q.y;
        °define •z1: °f32;
        °set •z1 = 1.0 - 2.0 * •q.y * •q.y + •q.z * •q.z;
        °set •result.z = •atan2f(•z0, •z1);
        °return •result;
      };
    };
