    <book>{
      °struct •Vector3 {
        •x: °f32;
        •y: °f32;
        •z: °f32;
      };

      °function •Vector3MoveTowards(
          •v: •Vector3,
          •target: •Vector3,
          •maxDistance: °f32
      ) -> •Vector3 {
        °define •result: •Vector3;
        °set •result.x = 0.0;
        °set •result.y = 0.0;
        °set •result.z = 0.0;
        °define •dx: °f32;
        °set •dx = •target.x - •v.x;
        °define •dy: °f32;
        °set •dy = •target.y - •v.y;
        °define •dz: °f32;
        °set •dz = •target.z - •v.z;
        °define •value: °f32;
        °set •value = •dx * •dx + •dy * •dy + •dz * •dz;
        °if (•value == 0 || •maxDistance >= 0 && •value <= •maxDistance * •maxDistance) {
          °return •target;
        };
        °define •dist: °f32;
        °set •dist = •sqrtf(•value);
        °set •result.x = •v.x + •dx / •dist * •maxDistance;
        °set •result.y = •v.y + •dy / •dist * •maxDistance;
        °set •result.z = •v.z + •dz / •dist * •maxDistance;
        °return •result;
      };
    };
