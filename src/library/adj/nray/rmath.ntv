        •m4: °f32;
        •m8: °f32;
        •m12: °f32;
        •m1: °f32;
        •m5: °f32;
        •m9: °f32;
        •m13: °f32;
        •m2: °f32;
        •m6: °f32;
        •m10: °f32;
        •m14: °f32;
        •m3: °f32;
        •m7: °f32;
        •m11: °f32;
        •m15: °f32;
      };

      °function •QuaternionToMatrix(
          •q: •Quaternion
      ) -> •Matrix {
        °define •result: •Matrix;
        °set •result.m0 = 1.0;
        °set •result.m4 = 0.0;
        °set •result.m8 = 0.0;
        °set •result.m12 = 0.0;
        °set •result.m1 = 0.0;
        °set •result.m5 = 1.0;
        °set •result.m9 = 0.0;
        °set •result.m13 = 0.0;
        °set •result.m2 = 0.0;
        °set •result.m6 = 0.0;
        °set •result.m10 = 1.0;
        °set •result.m14 = 0.0;
        °set •result.m3 = 0.0;
        °set •result.m7 = 0.0;
        °set •result.m11 = 0.0;
        °set •result.m15 = 1.0;
        °define •a2: °f32;
        °set •a2 = •q.x * •q.x;
        °define •b2: °f32;
        °set •b2 = •q.y * •q.y;
        °define •c2: °f32;
        °set •c2 = •q.z * •q.z;
        °define •ac: °f32;
        °set •ac = •q.x * •q.z;
        °define •ab: °f32;
        °set •ab = •q.x * •q.y;
        °define •bc: °f32;
        °set •bc = •q.y * •q.z;
        °define •ad: °f32;
        °set •ad = •q.w * •q.x;
        °define •bd: °f32;
        °set •bd = •q.w * •q.y;
        °define •cd: °f32;
        °set •cd = •q.w * •q.z;
        °set •result.m0 = 1 - 2 * •b2 + •c2;
        °set •result.m1 = 2 * •ab + •cd;
        °set •result.m2 = 2 * •ac - •bd;
        °set •result.m4 = 2 * •ab - •cd;
        °set •result.m5 = 1 - 2 * •a2 + •c2;
        °set •result.m6 = 2 * •bc + •ad;
        °set •result.m8 = 2 * •ac + •bd;
        °set •result.m9 = 2 * •bc - •ad;
        °set •result.m10 = 1 - 2 * •a2 + •b2;
        °return •result;
      };
