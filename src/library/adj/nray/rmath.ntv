        °set •right = •Vector3RotateByQuaternion(•right, •rotation);
        °set •up = •Vector3RotateByQuaternion(•up, •rotation);
        °set •forward = •Vector3RotateByQuaternion(•forward, •rotation);
        °define •result: •Matrix;
        °set •result.m0 = •right.x;
        °set •result.m4 = •up.x;
        °set •result.m8 = •forward.x;
        °set •result.m12 = •translation.x;
        °set •result.m1 = •right.y;
        °set •result.m5 = •up.y;
        °set •result.m9 = •forward.y;
        °set •result.m13 = •translation.y;
        °set •result.m2 = •right.z;
        °set •result.m6 = •up.z;
        °set •result.m10 = •forward.z;
        °set •result.m14 = •translation.z;
        °set •result.m3 = 0.0;
        °set •result.m7 = 0.0;
        °set •result.m11 = 0.0;
        °set •result.m15 = 1.0;
        °return •result;
      };
    };
