    <book>{
      °function •Vector3ToFloatV(
          •v: •Vector3
      ) -> •float3 {
        °define •buffer: •float3;
        °set •buffer = °tuple(0);
        °set °index(•buffer.v, 0) = •v.x;
        °set °index(•buffer.v, 1) = •v.y;
        °set °index(•buffer.v, 2) = •v.z;
        °return •buffer;
      };
    };
