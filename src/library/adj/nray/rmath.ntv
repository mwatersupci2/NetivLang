        °if (•fabsf(•v.z) < •source_min) {
          °define •tmp: •Vector3;
          °set •tmp.x = 0.0;
          °set •tmp.y = 0.0;
          °set •tmp.z = 1.0;
          °set •cardinalAxis = •tmp;
