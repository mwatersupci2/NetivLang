          °set •ilength = 1.0 / •length;
          °set •result.x = •q.x * •ilength;
          °set •result.y = •q.y * •ilength;
          °set •result.z = •q.z * •ilength;
          °set •result.w = •q.w * •ilength;
        };
        °return •result;
      };
