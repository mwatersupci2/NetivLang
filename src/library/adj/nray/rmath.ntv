    <meta>{
      name: "Clamp",
      kind: "function",
      version: "0.1.0",
      error: "terminal",
      deterministic: "true",
      export: "public",
      line: 145,
      memory: "stack-only",
      notes: "---------------------------------------------------------------------------------- Module Functions Definition - Utils math ---------------------------------------------------------------------------------- Clamp float value",
      page: 4,
      source: "RMath Library.pdf"
    };

    <edges>{
      %% Clamp -> CompareScalar
      %% Clamp -> ConditionalFlow
      %% Clamp -> f32
      %% RMath Library.pdf -> Clamp
    };

    <book>{
      °function •Clamp(
          •value: °f32,
          •source_min: °f32,
          •source_max: °f32
      ) -> °f32 {
        °define •result: °f32;
        °if (•value < •source_min) {
          °set •result = •source_min;
        };
        °otherwise {
          °set •result = •value;
        };
        °if (•result > •source_max) {
          °set •result = •source_max;
        };
        °return •result;
      };
    };
