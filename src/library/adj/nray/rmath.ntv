      °function •QuaternionToAxisAngle(
          •q: •Quaternion,
          •outAxis: °pointer<•Vector3>,
          •outAngle: °pointer<°f32>
      ) -> °void {
        °if (•fabsf(•q.w) > 1.0) {
          °define •length: °f32;
          °set •length = •sqrtf(•q.x * •q.x + •q.y * •q.y + •q.z * •q.z + •q.w * •q.w);
          °if (•length == 0.0) {
            °set •length = 1.0;
          };
          °define •ilength: °f32;
          °set •ilength = 1.0 / •length;
          °set •q.x = •q.x * •ilength;
          °set •q.y = •q.y * •ilength;
          °set •q.z = •q.z * •ilength;
          °set •q.w = •q.w * •ilength;
        };
        °define •resAxis: •Vector3;
        °set •resAxis.x = 0.0;
        °set •resAxis.y = 0.0;
        °set •resAxis.z = 0.0;
        °define •resAngle: °f32;
        °set •resAngle = 2.0 * •acosf(•q.w);
        °define •den: °f32;
        °set •den = •sqrtf(1.0 - •q.w * •q.w);
        °if (•den > •EPSILON) {
          °set •resAxis.x = •q.x / •den;
          °set •resAxis.y = •q.y / •den;
          °set •resAxis.z = •q.z / •den;
        };
        °otherwise {
          °set •resAxis.x = 1.0;
        };
        °set °deref(•outAxis) = •resAxis;
        °set °deref(•outAngle) = •resAngle;
      };
    };
