<Netiv="tui_test.ntv">
○|
  □|
    <meta>{
      "type": "module",
      "name": "test",
      "id": "test.tui",
      "version": "1.0.0",
      "notes": "Programmatic test script demonstrating unified Tachyons TUI rendering, stack buffer allocations for widgets/tabbars/pagers, and unmanaged I/O execution routes."
    };

    <edges>{
      %% test.tui -> adj.tachyons
    };

    <book>{
      °function •run_tui_demo() -> °void {
        °unsafe {
            °u8 •widget1_buf[64]
            °u8 •widget2_buf[64]
            
            °pointer<°struct •TuiWidget> •w1
            •w1 = °addr •widget1_buf
            °pointer<°struct •TuiWidget> •w2
            •w2 = °addr •widget2_buf

            °u8 •tabbar_buf[32]
            °u8 •pager_buf[32]

            °pointer<°struct •TuiTabBar> •tb
            •tb = °addr •tabbar_buf
            °pointer<°struct •TuiPager> •pg
            •pg = °addr •pager_buf

            °pointer<°const °u8> •tab1
            •tab1 = "DASHBOARD"
            °pointer<°const °u8> •tab2
            •tab2 = "SETTINGS"
            °pointer<°const °u8> •tab3
            •tab3 = "HELP"

            °pointer<°const °u8> •tab_arr[3]
            *(°pointer<°const °u8>*)(°addr •tab_arr) = •tab1
            *(°pointer<°const °u8>*)(°addr •tab_arr + 8) = •tab2
            *(°pointer<°const °u8>*)(°addr •tab_arr + 16) = •tab3

            °call •tachyons_init_tabbar(•tb, °addr •tab_arr, 3)
            *(°usize*)(•tb) = 2

            °call •tachyons_init_pager(•pg, 15, 5)
            *(°usize*)(•pg) = 1

            °call •tui_clear()
            °call •tui_show_cursor(°false)

            °call •tachyons_init_widget(•w1, "NETIV TACHYONS MULTI-PANEL TUI")
            °call •tachyons_widget_pos(•w1, 1, 1)
            °call •tachyons_widget_size(•w1, 46, 3)
            °call •tachyons_widget_border(•w1, 2)
            °call •tachyons_widget_color(•w1, 2, 1)
            °call •tachyons_render_tui(•w1)
            
            °call •tachyons_render_tabbar(•tb, •w1)

            °call •tachyons_init_widget(•w2, "STATUS: MULTI-PANEL PAGINATION ACTIVE")
            °call •tachyons_widget_pos(•w2, 1, 4)
            °call •tachyons_widget_size(•w2, 46, 3)
            °call •tachyons_widget_border(•w2, 1)
            °call •tachyons_widget_color(•w2, 3, 1)
            °call •tachyons_render_tui(•w2)

            °call •tachyons_render_pager_footer(•pg, •w2)

            °call •tui_show_cursor(°true)
            return
        }
      }

      °function •run_interactive_tui() -> °void {
        °unsafe {
            °call •tui_clear()
            °call •tui_show_cursor(°false)
            
            °usize •running
            •running = 1
            °label loop_start
            °if (•running == 1) {
                °goto loop_start
            }
            
            °call •tui_show_cursor(°true)
            return
        }
      }

      °function •run_io_test() -> °void {
        °unsafe {
            °call •println_native("--- Netiv Native I/O & Execution Test ---")
            
            °u8 •file_buf[256]
            °usize •bytes_read
            •bytes_read = °call •read_file("README.md", °addr •file_buf, 250)
            
            *(°u8*)(°addr •file_buf + •bytes_read) = 0
            
            °call •print_raw("Successfully read README.md content preview:\r\n", 46)
            °call •println_native(°addr •file_buf)
            
            °call •print_raw("Spawning external system echo command...\r\n", 42)
            °call •spawn_process("cmd.exe /c echo SUCCESS: Process spawned from Netiv!")
            return
        }
      }
    };
  |■
|●
</Netiv>
